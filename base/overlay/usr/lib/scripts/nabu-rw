#!/usr/bin/env bash
# nabu-rw - Toggle rootfs read-write mode for package installation
# Usage: nabu-rw on|off

set -euo pipefail

if [ "$(id -u)" -ne 0 ]; then
  echo "Error: must be run as root" >&2
  exit 1
fi

case "${1:-}" in
  on)
    echo "Remounting rootfs as read-write..."
    mount -o remount,rw /
    echo "Rootfs is now read-write. Install packages, then run: nabu-rw off"
    ;;
  off)
    echo "Remounting rootfs as read-only..."
    mount -o remount,ro /
    echo "Rootfs is now read-only."
    ;;
  *)
    echo "Usage: nabu-rw on|off" >&2
    echo "  on   - Remount rootfs as read-write for package installation"
    echo "  off  - Remount rootfs as read-only (recommended after changes)"
    exit 1
    ;;
esac
