# snapper config for user data
# NOTE: snapper rollback is NOT compatible with bootc/ostree.
# Use "bootc rollback" to revert to a previous deployment instead.
# Snapper only manages user data subvolumes (@home, @var).

SUBVOLUME="/home"
FSTYPE="btrfs"

# Users/groups allowed to work with snapshots
ALLOW_USERS=""
ALLOW_GROUPS="wheel"

# sync users and groups from ALLOW_USERS and ALLOW_GROUPS to .snapshots directory
SYNC_ACL="no"

# run daily number cleanup
NUMBER_CLEANUP="yes"
NUMBER_MIN_AGE="1800"
NUMBER_LIMIT="10"
NUMBER_LIMIT_IMPORTANT="5"

# timeline snapshots (hourly/daily)
TIMELINE_CREATE="yes"
TIMELINE_CLEANUP="yes"
TIMELINE_MIN_AGE="3600"
TIMELINE_LIMIT_HOURLY="3"
TIMELINE_LIMIT_DAILY="3"
TIMELINE_LIMIT_WEEKLY="0"
TIMELINE_LIMIT_MONTHLY="0"
TIMELINE_LIMIT_YEARLY="0"
